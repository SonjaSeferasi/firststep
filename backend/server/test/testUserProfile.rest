POST http://localhost:8081/user/editUser
Content-Type: application/json

{
  "userId": "69cc0fd86718737a9cb6c21a",
  "username": "james_boston",
  "email": "lily.chen@gmail.com",
  "password": "Lily@Boston24"
}

